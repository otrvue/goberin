generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  username         String        @unique
  password         String
  name             String?
  role             Role          @default(USER)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  apiKey           String?       @unique
  bukaolshopApiKey String?       @db.Text
  bukaolshopToken  String?       @db.Text
  callbackUrl      String?       @db.Text
  balances         BalanceLog[]
  transactions     Transaction[]

  @@map("users")
}

model VendorBalance {
  id          String   @id @default(uuid())
  vendor      Vendor   @unique
  balance     Decimal  @default(0.00) @db.Decimal(12, 2)
  lastChecked DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("vendor_balances")
}

model BalanceLog {
  id        String         @id @default(uuid())
  userId    String
  amount    Decimal        @db.Decimal(12, 2)
  type      BalanceLogType
  notes     String?
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "balance_logs_userId_fkey")
  @@map("balance_logs")
}

model Category {
  id        String        @id @default(uuid())
  name      String        @unique
  slug      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  markups   MarkupPrice[]
  products  Product[]

  @@map("categories")
}

model Provider {
  id        String        @id @default(uuid())
  name      String        @unique
  slug      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  markups   MarkupPrice[]
  products  Product[]

  @@map("providers")
}

model Product {
  id            String         @id @default(uuid())
  sku           String         @unique
  vendorSku     String
  vendor        Vendor
  type          ProductType
  name          String
  description   String?
  basePrice     Decimal        @db.Decimal(12, 2)
  isActive      Boolean        @default(true)
  categoryId    String
  providerId    String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  markups       MarkupPrice[]
  category      Category       @relation(fields: [categoryId], references: [id])
  provider      Provider       @relation(fields: [providerId], references: [id])
  promoProducts PromoProduct[]
  transactions  Transaction[]

  @@unique([vendor, vendorSku])
  @@index([categoryId], map: "products_categoryId_fkey")
  @@index([providerId], map: "products_providerId_fkey")
  @@map("products")
}

model MarkupPrice {
  id         String       @id @default(uuid())
  name       String
  target     MarkupTarget
  type       MarkupType
  value      Decimal      @db.Decimal(12, 2)
  isActive   Boolean      @default(true)
  priority   Int
  productId  String?
  providerId String?
  categoryId String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  provider   Provider?    @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([categoryId], map: "markup_prices_categoryId_fkey")
  @@index([productId], map: "markup_prices_productId_fkey")
  @@index([providerId], map: "markup_prices_providerId_fkey")
  @@map("markup_prices")
}

model Promo {
  id          String         @id @default(uuid())
  name        String
  description String?
  discount    Decimal        @db.Decimal(12, 2)
  type        MarkupType     @default(FIXED)
  startTime   DateTime
  endTime     DateTime
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  products    PromoProduct[]

  @@map("promos")
}

model PromoProduct {
  id        String  @id @default(uuid())
  promoId   String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  promo     Promo   @relation(fields: [promoId], references: [id], onDelete: Cascade)

  @@unique([promoId, productId])
  @@index([productId], map: "promo_products_productId_fkey")
  @@map("promo_products")
}

model Transaction {
  id                  String            @id @default(uuid())
  userId              String
  productId           String
  customerNo          String
  basePrice           Decimal           @db.Decimal(12, 2)
  markupPrice         Decimal           @db.Decimal(12, 2)
  promoDiscount       Decimal           @default(0.00) @db.Decimal(12, 2)
  totalPrice          Decimal           @db.Decimal(12, 2)
  status              TransactionStatus @default(PENDING)
  sn                  String?
  vendorTrxId         String?
  notes               String?           @db.Text
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  bukaolshopIdUser    String?
  bukaolshopTokenUser String?
  product             Product           @relation(fields: [productId], references: [id])
  user                User              @relation(fields: [userId], references: [id])

  @@index([productId], map: "transactions_productId_fkey")
  @@index([userId], map: "transactions_userId_fkey")
  @@map("transactions")
}

model SyncTask {
  id             String     @id @default(uuid())
  vendor         Vendor
  status         SyncStatus @default(PENDING)
  totalItems     Int        @default(0)
  processedItems Int        @default(0)
  createdCount   Int        @default(0)
  updatedCount   Int        @default(0)
  errorMessage   String?    @db.Text
  startTime      DateTime   @default(now())
  endTime        DateTime?
  updatedAt      DateTime   @updatedAt

  @@map("sync_tasks")
}

model VendorConfig {
  id        String   @id @default(uuid())
  vendor    Vendor   @unique
  config    Json
  updatedAt DateTime @updatedAt

  @@map("vendor_configs")
}

enum Role {
  ADMIN
  USER
}

enum BalanceLogType {
  TOPUP
  TRANSACTION
  REFUND
}

enum Vendor {
  DIGIFLAZZ
  OKECONNECT
}

enum ProductType {
  PREPAID
  POSTPAID
  INQUIRY
}

enum MarkupTarget {
  PRODUCT
  PROVIDER
  CATEGORY
  GLOBAL
}

enum MarkupType {
  FIXED
  PERCENTAGE
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  NOT_FOUND
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
